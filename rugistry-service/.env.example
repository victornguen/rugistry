# Environment variables for Rugistry

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://rugistry_user:rugistry_pass@localhost:5432/rugistry

# Server configuration
HOST=0.0.0.0
PORT=3000

# Logging level
RUST_LOG=info

# Event bus capacity (for WebSocket subscriptions)
EVENT_BUS_CAPACITY=100

# Keycloak configuration (optional, for future SSO integration)
# KEYCLOAK_URL=https://your-keycloak.com
# KEYCLOAK_REALM=your-realm
# KEYCLOAK_CLIENT_ID=rugistry-client
# KEYCLOAK_CLIENT_SECRET=your-secret
